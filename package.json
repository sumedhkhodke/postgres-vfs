{
  "name": "postgres-vfs",
  "version": "0.1.4",
  "description": "Virtual filesystem for AI agents backed by PostgreSQL — ChromaFs-equivalent using just-bash",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "import": "./dist/commands/index.js",
      "default": "./dist/commands/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sumedhkhodke/postgres-vfs.git"
  },
  "keywords": ["postgres", "virtual-filesystem", "ai-agents", "pgvector", "embeddings"],
  "scripts": {
    "migrate": "bun run src/db/migrate.ts",
    "test": "bun test",
    "ui": "bun run src/ui/server.ts",
    "build": "rm -rf dist && tsc",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "bash-tool": "^1.3.16",
    "just-bash": "^2.14.0",
    "pgvector": "^0.2.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  }
}
