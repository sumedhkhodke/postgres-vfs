# PostgreSQL connection string
DATABASE_URL=postgres://localhost:5432/postgres_vfs

# Default tenant ID
TENANT_ID=default

# Web UI port (default: 4321)
PORT=4321

# Anthropic API key for demo scripts
ANTHROPIC_API_KEY=

# Optional: enables automatic embedding generation for semantic search.
# When set, files are auto-embedded on write and search queries use vector similarity.
# When not set, search uses FTS + trigram only (still works, just no semantic matching).
OPENAI_API_KEY=

# Optional: OpenAI embedding model (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small
